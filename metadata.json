{
  "questions": {
    "start": {
      "question": "What kind of application are you building",
      "branch": {
        "options": [
          {"name": "Server","next": "AppName"},
          {"name": "Lambda","next": "LambdaType","context": {"set": "hbLambda"}}
        ]
      }
    },
    "AppName": {
      "question": "What would you like your executable to be named?",
      "text": {
        "prompt": "App Name: ",
        "validationRules": [
          "nonEmpty",
          "noWhitespace",
          "allASCII"
        ],
        "context": {"set": "hbExecutableName"},
        "next": "Features"
      }
    },
    "LambdaType": {
      "question": "What kind of lambda are you building",
      "select": {
        "options": [
          {"name": "APIGateway"},
          {"name": "APIGatewayV2"},
          {"name": "FunctionURL"}
        ],
        "context": {"set": "hbLambdaType"},
        "next": "LambdaFeatures"
      }
    },
    "Features": {
      "question": "Which features would you like to enable?",
      "multi-select": {
        "options": [
          {"name": "OpenAPI", "context": {"set": "hbOpenAPI"}},
          {"name": "WebSockets", "context": {"set": "hbWebSocket"}},
          {"name": "Visual Studio Code Snippets", "context": {"set": "hbVSCodeSnippets"}}
        ]
      }
    },
    "LambdaFeatures": {
      "question": "Which features would you like to enable?",
      "multi-select": {
        "options": [
          {"name": "OpenAPI", "context": "hbOpenAPI"},
          {"name": "Visual Studio Code Snippets", "context": {"set": "hbVSCodeSnippets"}}
        ]
      }
    }
  },
  "ignore": [
    ".github/workflows/test-configure.yml",
    ".vscode/settings.json",
    "configure.sh",
    "scripts/download.sh",
    "scripts/test_configure.sh",
    "README.md",
    "LICENSE",
    "metadata.json"
  ],
  "version": 3
}