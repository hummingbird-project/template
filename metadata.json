{
  "questions": [
    {
      "id": "app",
      "question": "What kind of application are you building",
      "branch": {
        "options": [
          {"name": "server", "displayName":"Server", "next": "name"},
          {"name": "lambda", "displayName":"Lambda", "next": "lambda","context": {"set": "hbLambda"}}
        ]
      }
    },
    {
      "id": "name",
      "question": "What would you like your executable to be named?",
      "text": {
        "prompt": "App Name: ",
        "validationRules": [
          "nonEmpty",
          "noWhitespace",
          "allASCII"
        ],
        "context": {"set": "hbExecutableName"},
        "next": "features"
      }
    },
    {
      "id": "lambda",
      "question": "What kind of lambda are you building",
      "select": {
        "options": [
          {"name": "APIGateway"},
          {"name": "APIGatewayV2"},
          {"name": "FunctionURL"}
        ],
        "context": {"set": "hbLambdaType"},
        "next": "lambda-features"
      }
    },
    {
      "id": "features",
      "question": "Which features would you like to enable?",
      "multi-select": {
        "options": [
          {"name": "openapi", "displayName":"OpenAPI", "context": {"set": "hbOpenAPI"}},
          {"name": "websockets", "displayName":"WebSockets", "context": {"set": "hbWebSocket"}},
          {"name": "vscode", "displayName":"Visual Studio Code Support", "context": {"set": "hbVSCodeSnippets"}}
        ]
      }
    },
    {
      "id": "lambda-features",
      "question": "Which features would you like to enable?",
      "multi-select": {
        "options": [
          {"name": "openapi", "displayName":"OpenAPI", "context": {"set": "hbOpenAPI"}},
          {"name": "vscode", "displayName":"Visual Studio Code Support", "context": {"set": "hbVSCodeSnippets"}}
        ]
      }
    }
  ],
  "ignore": [
    ".github/workflows/test-configure.yml",
    ".vscode/settings.json",
    "configure.sh",
    "scripts/download.sh",
    "scripts/test_configure.sh",
    "README.md",
    "LICENSE",
    "metadata.json"
  ],
  "version": 3
}